{
  "manifest_version": 3,
  "name": "Help me Focus",
  "version": "0.1.0",
  "description": "Block websites by schedule.",
  "permissions": ["storage", "alarms", "declarativeNetRequest", "declarativeNetRequestFeedback"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "Help me Focus",
    "default_popup": "src/popup/popup.html"
  }
}
